# Twilio credentials — get these at console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here

# Twilio phone number in E.164 format (e.g. +15551234567)
TWILIO_FROM_NUMBER=+15551234567

# Your iPhone number in E.164 format
NOTIFY_PHONE_NUMBER=+15559876543

# How often to poll in milliseconds (default: 60000 = 1 minute)
POLL_INTERVAL_MS=60000
