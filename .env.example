# Your unique ntfy.sh topic — make this hard to guess so only you get alerts
# Subscribe to this topic in the ntfy iOS app
NTFY_TOPIC=alexzono-restock-abc123

# How often to poll in milliseconds (default: 60000 = 1 minute)
POLL_INTERVAL_MS=60000

# Shipping details used to build the "Fast checkout" link when cart links mode is
# "checkout" (config.json → cartLinks.mode). Only read locally, never committed.
# Leave any of these blank to omit that field from the pre-filled checkout link.
CHECKOUT_EMAIL=
CHECKOUT_FIRST_NAME=
CHECKOUT_LAST_NAME=
CHECKOUT_ADDRESS1=
CHECKOUT_ADDRESS2=
CHECKOUT_CITY=
CHECKOUT_PROVINCE=
CHECKOUT_ZIP=
CHECKOUT_COUNTRY=
CHECKOUT_PHONE=
